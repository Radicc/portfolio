ith a desire to learn and grow in\r\n              a collaborative team environment. Skilled in HTML, CSS, and\r\n              JavaScript. Specializing in ReactJS library.\r\n            </h3>\r\n          </div>\r\n\r\n          <div className=\"notSliderContainer\">\r\n            <img className=\"notSliderImg\" src={Programmer} />\r\n          </div>\r\n        </div>\r\n        <Slider />\r\n      </div>\r\n      <Tooler />\r\n      <MyProjects />\r\n\r\n      <Footer CV={CV} Mailos={Mailos} setCV={setCV} setMail={setMail} />\r\n    </div>\r\n  );\r\n}\r\nexport default App;\r\n","C:\\Users\\Radicc\\Desktop\\PROFILE\\profile\\src\\jsx\\tooler.js",["59","60","61","62","63","64","65","66","67","68","69","70","71","72","73"],[],"import React, { Component } from \"react\";\r\nimport \"../css/App.css\";\r\n\r\nimport HTMLlogo from \"../images/HTML5logo.png\";\r\nimport CSSlogo from \"../images/CSS3logo.png\";\r\nimport SASSlogo from \"../images/SASSlogo.png\";\r\nimport JSlogo from \"../images/JSlogo.png\";\r\nimport TSlogo from \"../images/TSlogo.png\";\r\nimport REACTlogo from \"../images/REACTlogo.png\";\r\nimport WEBPACKlogo from \"../images/WEBPACKlogo.png\";\r\nimport GITlogo from \"../images/GITlogo.png\";\r\n\r\nexport default function Tooler() {\r\n  return (\r\n    <div className=\"toolsBar\">\r\n      <img className=\"toolsLogo\" src={HTMLlogo} />\r\n\r\n      <img className=\"toolsLogo\" src={CSSlogo} />\r\n\r\n      <img className=\"toolsLogo\" src={SASSlogo} />\r\n\r\n      <img className=\"toolsLogo\" src={JSlogo} />\r\n\r\n      <img className=\"toolsLogo\" src={REACTlogo} />\r\n\r\n      <img className=\"toolsLogo\" src={GITlogo} />\r\n      <div className=\"div1\">\r\n        <img className=\"toolsLogo2\" src={HTMLlogo} />\r\n\r\n        <img className=\"toolsLogo2\" src={CSSlogo} />\r\n\r\n        <img className=\"toolsLogo2\" src={JSlogo} />\r\n      </div>\r\n      <div className=\"div2\">\r\n        <img className=\"toolsLogo2\" src={REACTlogo} />\r\n\r\n        <img className=\"toolsLogo2\" src={SASSlogo} />\r\n\r\n        <img className=\"toolsLogo2\" src={GITlogo} />\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","C:\\Users\\Radicc\\Desktop\\PROFILE\\profile\\src\\jsx\\nav.js",["74","75","76","77","78","79","80","81"],[],"import React from \"react\";\r\nimport { useState } from \"react\";\r\n\r\nimport \"../css/BurgerMenu.css\";\r\nimport \"../css/Header.css\";\r\n\r\nimport gitHub from \"../images/GitHub.png\";\r\nimport linkedIN from \"../images/linkedIN.png\";\r\nimport twitter from \"../images/twitterLogo.png\";\r\nimport instagram from \"../images/instagram.png\";\r\n\r\nexport default function Nav(props) {\r\n  const [Active, IsActive] = useState(\"off\");\r\n  const [Style, setStyle] = useState(\"pushMenuHidden\");\r\n  const [Burger, setBurger] = useState(\"\");\r\n\r\n  const handleClick3 = () => {\r\n    IsActive(\"off\");\r\n    setStyle(\"pushMenuHidden\");\r\n    setBurger(\"\");\r\n    props.setCV(\"CvForm-Footer2\");\r\n  };\r\n  const handleClick2 = () => {\r\n    IsActive(\"off\");\r\n    setStyle(\"pushMenuHidden\");\r\n    setBurger(\"\");\r\n    props.setMail(\"contactBackgroundFlex\");\r\n  };\r\n\r\n  const handleClick = () => {\r\n    if (Active === \"off\") {\r\n      IsActive(\"true\");\r\n      setStyle(\"pushMenuDown\");\r\n      setBurger(\"open\");\r\n    } else {\r\n      IsActive(\"off\");\r\n      setStyle(\"pushMenuHidden\");\r\n      setBurger(\"\");\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"headerContainer\">\r\n      <div onClick={handleClick} id=\"nav-icon2\" className={Burger}>\r\n        <span></span>\r\n        <span></span>\r\n        <span></span>\r\n        <span></span>\r\n        <span></span>\r\n        <span></span>\r\n      </div>\r\n      <a className=\"Radicc\" href=\"#Home\">\r\n        RADICC\r\n      </a>\r\n\r\n      <div className={Style}>\r\n        <div className=\"containerNav\">\r\n          <div className=\"greenBox\"></div>\r\n          <ul className=\"ulNav\">\r\n            <li>\r\n              <a onClick={handleClick} href=\"#Home\">\r\n                Home\r\n              </a>\r\n            </li>\r\n            <li>\r\n              <a onClick={handleClick} href=\"#Projects\">\r\n                Portfolio\r\n              </a>\r\n            </li>\r\n            <li>\r\n              <a onClick={handleClick3} href=\"#cvButt\">\r\n                CV\r\n              </a>\r\n            </li>\r\n            <li>\r\n              <a onClick={handleClick2} href=\"#Contact\">\r\n                Contact\r\n              </a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n\r\n        <div className=\"containerSocial\">\r\n          <a\r\n            className=\"social1\"\r\n            href=\"https://github.com/Radicc\"\r\n            target=\"_blank\"\r\n          >\r\n            <img className=\"imgSocial\" src={gitHub} />\r\n            <p className=\"socialText\">GitHub</p>\r\n          </a>\r\n\r\n          <a\r\n            className=\"social2\"\r\n            href=\"https://www.linkedin.com/in/tomas-radicc/\"\r\n            target=\"_blank\"\r\n          >\r\n            <img className=\"imgSocial\" src={linkedIN} />\r\n            <p className=\"socialText\">LinkedIn</p>\r\n          </a>\r\n\r\n          <a\r\n            className=\"social3\"\r\n            href=\"https://twitter.com/TomRadi1\"\r\n            target=\"_blank\"\r\n          >\r\n            <img className=\"imgSocial\" src={twitter} />\r\n            <p className=\"socialText\">Twitter</p>\r\n          </a>\r\n\r\n          <a\r\n            className=\"social4\"\r\n            href=\"https://www.instagram.com/radic.o_o/\"\r\n            target=\"_blank\"\r\n          >\r\n            <img className=\"imgSocial\" src={instagram} />\r\n            <p className=\"socialText\">Instagram</p>\r\n          </a>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","C:\\Users\\Radicc\\Desktop\\PROFILE\\profile\\src\\jsx\\Slider.js",[],[],"C:\\Users\\Radicc\\Desktop\\PROFILE\\profile\\src\\jsx\\Footer.js",["82","83","84","85","86","87","88","89","90","91","92"],[],"import { useState } from \"react\";\r\nimport \"../css/App.css\";\r\nimport \"../css/Footer.css\";\r\nimport \"../css/Header.css\";\r\nimport Mail from \"../images/mail.png\";\r\nimport \"../css/CvButton.scss\";\r\nimport \"../css/ContactSubmit.scss\";\r\n\r\nimport gitHub from \"../images/GitHub.png\";\r\nimport linkedIN from \"../images/linkedIN.png\";\r\nimport twitter from \"../images/twitterLogo.png\";\r\nimport instagram from \"../images/instagram.png\";\r\nimport avatar from \"../images/avatar.jpg\";\r\n\r\nexport default function Footer(props) {\r\n  //const [show, setShow] = useState(\"CvForm-Footer2None\");\r\n  const [ide, setIde] = useState(\"cvButt\");\r\n\r\n  //const [contact, setContact] = useState(\"contactBackgroundNone\");\r\n\r\n  const showCv = () => {\r\n    if (props.CV === \"CvForm-Footer2None\") {\r\n      props.setCV(\"CvForm-Footer2\");\r\n      setTimeout(() => setIde(\"ide\"), 2000);\r\n    } else {\r\n      props.setCV(\"CvForm-Footer2None\");\r\n      setIde(\"cvButt\");\r\n    }\r\n  };\r\n\r\n  const showContact = () => {\r\n    if (props.Mailos === \"contactBackgroundNone\") {\r\n      props.setMail(\"contactBackgroundFlex\");\r\n    } else {\r\n      props.setMail(\"contactBackgroundNone\");\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"containerFooter\">\r\n      <div className=\"buttonContainer\">\r\n        <a id=\"cvButt\" href={\"#\" + ide} onClick={showCv} className=\"Cvbutton\">\r\n          <span></span>\r\n          <span></span>\r\n          <span></span>\r\n          <span></span>\r\n          CV\r\n        </a>\r\n      </div>\r\n\r\n      <div id=\"ide\" className={props.CV}>\r\n        <div className=\"WhitePaper\">\r\n          <div className=\"LeftPaper\">\r\n            <img className=\"CvPicture\" src={avatar}></img>\r\n            <div className=\"Education\">\r\n              <h2>Education</h2>\r\n              <p>Secondary School of Electrical Engineering</p>\r\n              <p> Bratislava / Slovakia </p>\r\n              <p> 2016-2020</p>\r\n            </div>\r\n            <div className=\"CvContact\">\r\n              <h3>Phone</h3>\r\n              <p>+421 951 421 115</p>\r\n\r\n              <h3>Email</h3>\r\n              <p>tomas.radic00@gmail.com</p>\r\n\r\n              <h3>Website</h3>\r\n              <a>https://radicc.github.io/Portfolio/</a>\r\n\r\n              <h3>Address</h3>\r\n              <p>Malacky, Slovakia</p>\r\n            </div>\r\n          </div>\r\n          <div className=\"RightPaper\">\r\n            <div className=\"NameTitul\">\r\n              <h1>TOMÁŠ RADIČ</h1>\r\n              <p>SELFTHOUGHT FRONTEND DEVELOPER</p>\r\n            </div>\r\n            <div className=\"AboutMe\">\r\n              <h3 className=\"titles\">ABOUT ME</h3>\r\n              <p>\r\n                Passionate self-taught student of frontend development trying to\r\n                change profession. Desire to learn and grow in a collaborative\r\n                team environment.\r\n              </p>\r\n            </div>\r\n            <div className=\"AboutMe\">\r\n              <h3 className=\"titles\">WORK EXPERIENCE</h3>\r\n              <p>\r\n                ● Representative portfolio - Information about me and my skills.\r\n              </p>\r\n              <p>\r\n                ● Educational platform - Investment-free educational project for\r\n                people who want to improve in asset management.\r\n              </p>\r\n            </div>\r\n            <div className=\"AboutMe\">\r\n              <h3 className=\"titles\">SOFTWARE SKILL</h3>\r\n              <p>\r\n                ●HTML, ●CSS, ●SASS, ●Javascript, ●React, ●GIT, ●Adobe Photoshop,\r\n                ●Blender\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div className=\"Footer1\">\r\n        <a\r\n          className=\"socialFooterContainer1\"\r\n          href=\"https://github.com/Radicc\"\r\n          target=\"_blank\"\r\n        >\r\n          <img className=\"footerSocial\" src={gitHub} />\r\n          <p className=\"footerText\">GitHub</p>\r\n        </a>\r\n        <a\r\n          className=\"socialFooterContainer2\"\r\n          href=\"https://www.linkedin.com/in/tomas-radicc/\"\r\n          target=\"_blank\"\r\n        >\r\n          <img className=\"footerSocial\" src={linkedIN} />\r\n          <p className=\"footerText\">LinkedIn</p>\r\n        </a>\r\n        <a\r\n          className=\"socialFooterContainer3\"\r\n          href=\"https://twitter.com/TomRadi1\"\r\n          target=\"_blank\"\r\n        >\r\n          <img className=\"footerSocial\" src={twitter} />\r\n          <p className=\"footerText\">Twitter</p>\r\n        </a>\r\n        <a\r\n          className=\"socialFooterContainer4\"\r\n          href=\"https://www.instagram.com/radic.o_o/\"\r\n          target=\"_blank\"\r\n        >\r\n          <img className=\"footerSocial\" src={instagram} />\r\n          <p className=\"footerText\">Instagram</p>\r\n        </a>\r\n      </div>\r\n\r\n      <div id=\"Contact\" className=\"Footer2\">\r\n        <a href=\"#Contact\" onClick={showContact}>\r\n          MAIL ME NOW!\r\n        </a>\r\n        <img src={Mail} />\r\n      </div>\r\n\r\n      <form\r\n        action=\"https://formsubmit.co/tomas.radic00@gmail.com\"\r\n        method=\"POST\"\r\n        className={props.Mailos}\r\n      >\r\n        <div className=\"contactContainer\">\r\n          <h1>CONTACT ME</h1>\r\n          <input type=\"hidden\" name=\"_subject\" value=\"New submission!\"></input>\r\n          <input\r\n            type=\"text\"\r\n            id=\"name\"\r\n            name=\"name\"\r\n            placeholder=\"Name\"\r\n            spellCheck=\"false\"\r\n            required\r\n          />\r\n          <input\r\n            type=\"email\"\r\n            id=\"email\"\r\n            name=\"email\"\r\n            placeholder=\"Email\"\r\n            spellCheck=\"false\"\r\n            required\r\n          />\r\n          <input\r\n            type=\"text\"\r\n            id=\"phone\"\r\n            name=\"phone\"\r\n            placeholder=\"Phone Number\"\r\n            spellCheck=\"false\"\r\n            required\r\n          />\r\n          <textarea\r\n            rows=\"4\"\r\n            id=\"message\"\r\n            name=\"message\"\r\n            placeholder=\"How can i help you?\"\r\n            spellCheck=\"false\"\r\n          ></textarea>\r\n          <div className=\"CVbutton2Container\">\r\n            <button type=\"submit\" className=\"ContactSubmit\">\r\n              <span></span>\r\n              <span></span>\r\n              <span></span>\r\n              <span></span>\r\n              SUBMIT\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </form>\r\n\r\n      <div className=\"Footer3\">\r\n        <p>© Copyright 2022, Tomas Radic All Rights Reserved.</p>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n",{"ruleId":"93","severity":1,"message":"94","line":21,"column":9,"nodeType":"95","endLine":27,"endColumn":10},{"ruleId":"93","severity":1,"message":"94","line":31,"column":13,"nodeType":"95","endLine":31,"endColumn":35},{"ruleId":"93","severity":1,"message":"94","line":32,"column":13,"nodeType":"95","endLine":32,"endColumn":35},{"ruleId":"93","severity":1,"message":"94","line":33,"column":13,"nodeType":"95","endLine":33,"endColumn":41},{"ruleId":"93","severity":1,"message":"94","line":34,"column":13,"nodeType":"95","endLine":34,"endColumn":36},{"ruleId":"93","severity":1,"message":"94","line":35,"column":13,"nodeType":"95","endLine":35,"endColumn":34},{"ruleId":"93","severity":1,"message":"94","line":103,"column":13,"nodeType":"95","endLine":103,"endColumn":35},{"ruleId":"93","severity":1,"message":"94","lin