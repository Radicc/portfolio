t-png/js-logo-png-5.png\"\r\n      />\r\n\r\n      <img\r\n        className=\"toolsLogo\"\r\n        src=\"https://cdn.worldvectorlogo.com/logos/typescript-2.svg\"\r\n      />\r\n\r\n      <img\r\n        className=\"toolsLogo\"\r\n        src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a7/React-icon.svg/2300px-React-icon.svg.png\"\r\n      />\r\n\r\n      <img\r\n        className=\"toolsLogo\"\r\n        src=\"https://raw.githubusercontent.com/webpack/media/master/logo/icon-square-big.png\"\r\n      />\r\n\r\n      <img\r\n        className=\"toolsLogo\"\r\n        src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a1/AJAX_logo_by_gengns.svg/2560px-AJAX_logo_by_gengns.svg.png\"\r\n      />\r\n\r\n      <img\r\n        className=\"toolsLogo\"\r\n        src=\"https://git-scm.com/images/logos/downloads/Git-Icon-1788C.png\"\r\n      />\r\n      <div className=\"div1\">\r\n        <img\r\n          className=\"toolsLogo2\"\r\n          src=\"https://www.freepnglogos.com/uploads/html5-logo-png/html5-logo-html-logo-0.png\"\r\n        />\r\n\r\n        <img\r\n          className=\"toolsLogo2\"\r\n          src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/6/62/CSS3_logo.svg/800px-CSS3_logo.svg.png\"\r\n        />\r\n\r\n        <img\r\n          className=\"toolsLogo2\"\r\n          src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/9/96/Sass_Logo_Color.svg/1280px-Sass_Logo_Color.svg.png\"\r\n        />\r\n\r\n        <img\r\n          className=\"toolsLogo2\"\r\n          src=\"https://www.freepnglogos.com/uploads/javascript-png/js-logo-png-5.png\"\r\n        />\r\n      </div>\r\n      <div className=\"div2\">\r\n        <img\r\n          className=\"toolsLogo2\"\r\n          src=\"https://cdn.worldvectorlogo.com/logos/typescript-2.svg\"\r\n        />\r\n\r\n        <img\r\n          className=\"toolsLogo2\"\r\n          src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a7/React-icon.svg/2300px-React-icon.svg.png\"\r\n        />\r\n\r\n        <img\r\n          className=\"toolsLogo2\"\r\n          src=\"https://raw.githubusercontent.com/webpack/media/master/logo/icon-square-big.png\"\r\n        />\r\n\r\n        <img\r\n          className=\"toolsLogo2\"\r\n          src=\"https://git-scm.com/images/logos/downloads/Git-Icon-1788C.png\"\r\n        />\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","C:\\Users\\Radicc\\Desktop\\PROFILE\\profile\\src\\myProjects.js",["305","306","307","308"],[],"C:\\Users\\Radicc\\Desktop\\PROFILE\\profile\\src\\Footer.js",["309","310","311","312","313","314","315","316","317","318","319"],[],"import { useState } from \"react\";\r\nimport \"./App.css\";\r\nimport \"./Footer.css\";\r\nimport Mail from \"../src/images/mail.png\";\r\nimport \"./CvButton.scss\";\r\nimport \"./ContactSubmit.scss\";\r\n\r\nexport default function Footer(props) {\r\n  //const [show, setShow] = useState(\"CvForm-Footer2None\");\r\n  const [ide, setIde] = useState(\"cvButt\");\r\n\r\n  //const [contact, setContact] = useState(\"contactBackgroundNone\");\r\n\r\n  const showCv = () => {\r\n    if (props.CV === \"CvForm-Footer2None\") {\r\n      props.setCV(\"CvForm-Footer2\");\r\n      setTimeout(() => setIde(\"ide\"), 2000);\r\n    } else {\r\n      props.setCV(\"CvForm-Footer2None\");\r\n      setIde(\"cvButt\");\r\n    }\r\n  };\r\n\r\n  const showContact = () => {\r\n    if (props.Mailos === \"contactBackgroundNone\") {\r\n      props.setMail(\"contactBackgroundFlex\");\r\n    } else {\r\n      props.setMail(\"contactBackgroundNone\");\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"containerFooter\">\r\n      <a id=\"cvButt\" href={\"#\" + ide} onClick={showCv} className=\"Cvbutton\">\r\n        <span></span>\r\n        <span></span>\r\n        <span></span>\r\n        <span></span>\r\n        CV\r\n      </a>\r\n      <div id=\"ide\" className={props.CV}>\r\n        <div className=\"WhitePaper\">\r\n          <div className=\"LeftPaper\">\r\n            <img\r\n              className=\"CvPicture\"\r\n              src=\"https://www.fredericvigier.com/wp-content/uploads/2021/01/directeur-communication-photo-cv.jpg\"\r\n            ></img>\r\n            <div className=\"Education\">\r\n              <h2>Education</h2>\r\n              <p>Secondary School of Electrical Engineering</p>\r\n              <p> Bratislava / Slovakia </p>\r\n              <p> 2016-2020</p>\r\n            </div>\r\n            <div className=\"Reference\">\r\n              <h2>Reference</h2>\r\n              <p>GAOL Energy Slovakia, s.r.o.</p>\r\n              <p>Elektrikár</p>\r\n              <p>2021 - 2022</p>\r\n            </div>\r\n            <div className=\"CvContact\">\r\n              <h3>Phone</h3>\r\n              <p>+421 000 000 000</p>\r\n\r\n              <h3>Email</h3>\r\n              <p>tomas.radic00@gmail.com</p>\r\n\r\n              <h3>Website</h3>\r\n              <a>https://radicc.github.io/Portfolio/</a>\r\n\r\n              <h3>Address</h3>\r\n              <p>Malacky, Slovakia</p>\r\n            </div>\r\n          </div>\r\n          <div className=\"RightPaper\">\r\n            <div className=\"NameTitul\">\r\n              <h1>TOMÁŠ RADIČ</h1>\r\n              <p>SELFTHOUGHT FRONTEND DEVELOPER</p>\r\n            </div>\r\n            <div className=\"AboutMe\">\r\n              <h3 className=\"titel1\">ABOUT ME</h3>\r\n              <p>\r\n                I am a self-taught student of frontend developing trying to\r\n                change profession. Experienced in HTML,CSS and JavaScript\r\n                specializing in ReactJS library. Implementing CSS-extansion SASS\r\n                and JavaScript-syntactical superset TypeScript.\r\n              </p>\r\n            </div>\r\n            <div className=\"AboutMe\">\r\n              <h3 className=\"titel2\">WORK EXPERIENCE</h3>\r\n              <p>\r\n                My journey is recorded on this website. Each project is designed\r\n                so that I can get a job as a Frontend developer.\r\n              </p>\r\n            </div>\r\n            <div className=\"AboutMe\">\r\n              <h3 className=\"titel3\">SOFTWARE SKILL</h3>\r\n              <p>HTML, CSS, SASS, JAVASCRIPT, TYPESCRIPT, REACT.JS, GIT</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div className=\"Footer1\">\r\n        <a\r\n          className=\"socialFooterContainer1\"\r\n          href=\"https://github.com/Radicc\"\r\n          target=\"_blank\"\r\n        >\r\n          <img\r\n            className=\"footerSocial\"\r\n            src=\"https://cdn-icons-png.flaticon.com/512/25/25231.png\"\r\n          />\r\n          <p className=\"footerText\">GitHub</p>\r\n        </a>\r\n        <a\r\n          className=\"socialFooterContainer2\"\r\n          href=\"https://www.linkedin.com/in/tom%C3%A1%C5%A1-radi%C4%8D-068044221/\"\r\n          target=\"_blank\"\r\n        >\r\n          <img\r\n            className=\"footerSocial\"\r\n            src=\"https://cdn-icons-png.flaticon.com/512/174/174857.png\"\r\n          />\r\n          <p className=\"footerText\">LinkedIn</p>\r\n        </a>\r\n        <a\r\n          className=\"socialFooterContainer3\"\r\n          href=\"https://twitter.com/TomRadi1\"\r\n          target=\"_blank\"\r\n        >\r\n          <img\r\n            className=\"footerSocial\"\r\n            src=\"https://www.pngkey.com/png/full/2-27646_twitter-logo-png-transparent-background-logo-twitter-png.png\"\r\n          />\r\n          <p className=\"footerText\">Twitter</p>\r\n        </a>\r\n        <a\r\n          className=\"socialFooterContainer4\"\r\n          href=\"https://www.instagram.com/radic.o_o/\"\r\n          target=\"_blank\"\r\n        >\r\n          <img\r\n            className=\"footerSocial\"\r\n            src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a5/Instagram_icon.png/640px-Instagram_icon.png\"\r\n          />\r\n          <p className=\"footerText\">Instagram</p>\r\n        </a>\r\n      </div>\r\n\r\n      <div id=\"Contact\" className=\"Footer2\">\r\n        <a href=\"#Contact\" onClick={showContact}>\r\n          MAIL ME NOW!\r\n        </a>\r\n        <img src={Mail} />\r\n      </div>\r\n\r\n      <form\r\n        action=\"https://formsubmit.co/tomas.radic00@gmail.com\"\r\n        method=\"POST\"\r\n        className={props.Mailos}\r\n      >\r\n        <div className=\"contactContainer\">\r\n          <h1>CONTACT ME</h1>\r\n          <input type=\"hidden\" name=\"_subject\" value=\"New submission!\"></input>\r\n          <input\r\n            type=\"text\"\r\n            id=\"name\"\r\n            name=\"name\"\r\n            placeholder=\"Name\"\r\n            spellCheck=\"false\"\r\n            required\r\n          />\r\n          <input\r\n            type=\"email\"\r\n            id=\"email\"\r\n            name=\"email\"\r\n            placeholder=\"Email\"\r\n            spellCheck=\"false\"\r\n            required\r\n          />\r\n          <input\r\n            type=\"text\"\r\n            id=\"phone\"\r\n            name=\"phone\"\r\n            placeholder=\"Phone Number\"\r\n            spellCheck=\"false\"\r\n            required\r\n          />\r\n          <textarea\r\n            rows=\"4\"\r\n            id=\"message\"\r\n            name=\"message\"\r\n            placeholder=\"How can i help you?\"\r\n            spellCheck=\"false\"\r\n          ></textarea>\r\n          <button type=\"submit\" className=\"ContactSubmit\">\r\n            <span></span>\r\n            <span></span>\r\n            <span></span>\r\n            <span></span>\r\n            SUBMIT\r\n          </button>\r\n        </div>\r\n      </form>\r\n\r\n      <div className=\"Footer3\">\r\n        <p>© Copyright 2022, Tomas Radic All Rights Reserved.</p>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n",{"ruleId":"320","severity":1,"message":"321","line":35,"column":13,"nodeType":"322","endLine":35,"endC