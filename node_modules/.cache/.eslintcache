\\nav.js",["142","143","144","145","146","147","148","149"],[],"C:\\Users\\Radicc\\Desktop\\Portfolio-main\\src\\myProjects.js",["150","151"],[],"C:\\Users\\Radicc\\Desktop\\Portfolio-main\\src\\Footer.js",["152","153","154","155","156","157","158","159","160","161","162","163"],[],"C:\\Users\\Radicc\\Desktop\\Portfolio\\Portfolio\\src\\index.js",[],[],"C:\\Users\\Radicc\\Desktop\\Portfolio\\Portfolio\\src\\App.js",["164"],[],"import \"./App.css\";\nimport \"./nav.css\";\nimport Slider from \"./Slider\";\nimport Nav from \"./nav\";\nimport Tooler from \"./tooler\";\nimport MyProjects from \"./myProjects\";\nimport Footer from \"./Footer\";\n\nimport Programmer from \"./images/programmer2.png\";\n\nfunction App() {\n  return (\n    <div id=\"Home\" className=\"App\">\n      <div className=\"header\">\n        <Nav />\n        <h3 className=\"Radicc\">RADICC</h3>\n      </div>\n\n      <div className=\"body\">\n        <div className=\"container\">\n          <div className=\"divTomRad\">\n            <div className=\"divHi\">\n              <h2 className=\"tomRadHi\">✌ Hi There! I'm Radicc</h2>\n            </div>\n            <h1 className=\"tomRadText\">A Frontend developer</h1>\n            <h3 className=\"tomRadUnderText\">\n              I am a selfthouhgt student of frontend developing trying to change\n              profession. Experienced in HTML,CSS and JavaScript specializing in\n              ReactJS library. Implementing CSS-extansion SASS and\n              JavaScript-syntactical superset TypeScript.\n            </h3>\n          </div>\n\n          <div className=\"notSliderContainer\">\n            <img className=\"notSliderImg\" src={Programmer} />\n          </div>\n        </div>\n        <Slider />\n      </div>\n      <Tooler />\n      <MyProjects />\n\n      <Footer />\n    </div>\n  );\n}\nexport default App;\n","C:\\Users\\Radicc\\Desktop\\Portfolio\\Portfolio\\src\\reportWebVitals.js",[],[],"C:\\Users\\Radicc\\Desktop\\Portfolio\\Portfolio\\src\\Slider.js",["165"],[],"import React, { useEffect, useState } from \"react\";\nimport \"./App.css\";\nimport \"./slider.css\";\nimport Image1 from \"../src/images/jaja2.jpg\";\nimport Image2 from \"../src/images/photo2.jpg\";\n\nexport default function Slider() {\n  //const [Number, setNumber] = useState(0);\n  const Images = [Image1, Image2];\n\n  const [Count, setCount] = useState(0);\n\n  useEffect(() => {\n    const interval = setInterval(updateCount, 8000);\n    return () => clearInterval(interval);\n  }, [Count]);\n\n  const updateCount = () => {\n    if (Count < Images.length - 1) {\n      setCount(Count + 1);\n    } else {\n      setCount(0);\n    }\n  };\n\n  return (\n    <div className=\"divSlider\">\n      <img className=\"photo1\" src={Images[Count]} alt=\"programmingPhoto1\" />\n    </div>\n  );\n}\n","C:\\Users\\Radicc\\Desktop\\Portfolio\\Portfolio\\src\\nav.js",["166","167","168","169","170","171","172","173"],[],"import React from \"react\";\nimport { useState } from \"react\";\nimport \"./nav.css\";\nimport \"./BurgerMenu.css\";\n\nexport default function Nav() {\n  const [Active, IsActive] = useState(\"off\");\n  const [Style, setStyle] = useState(\"pushMenuHidden\");\n  const [Burger, setBurger] = useState(\"\");\n\n  const handleClick = () => {\n    if (Active === \"off\") {\n      IsActive(\"true\");\n      setStyle(\"pushMenuDown\");\n      setBurger(\"open\");\n    } else {\n      IsActive(\"off\");\n      setStyle(\"pushMenuHidden\");\n      setBurger(\"\");\n    }\n  };\n\n  return (\n    <div>\n      <div className={Style}>\n        <div className=\"containerNav\">\n          <div className=\"greenBox\"></div>\n          <ul className=\"ulNav\">\n            <li>\n              <a onClick={handleClick} href=\"#Home\">\n                Home\n              </a>\n            </li>\n            <li>\n              <a onClick={handleClick} href=\"#Projects\">\n                Portfolio\n              </a>\n            </li>\n            <li>\n              <a onClick={handleClick} href=\"#Cv\">\n                CV\n              </a>\n            </li>\n            <li>\n              <a onClick={handleClick} href=\"#Contact\">\n                Contact\n              </a>\n            </li>\n          </ul>\n        </div>\n        <div className=\"containerSocial\">\n          <a\n            className=\"social1\"\n            href=\"https://github.com/Radicc\"\n            target=\"_blank\"\n          >\n            <img\n              className=\"imgSocial\"\n              src=\"https://cdn-icons-png.flaticon.com/512/25/25231.png\"\n            />\n            <p className=\"socialText\">GitHub</p>\n          </a>\n\n          <a\n            className=\"social2\"\n            href=\"https://www.linkedin.com/in/tom%C3%A1%C5%A1-radi%C4%8D-068044221/\"\n            target=\"_blank\"\n          >\n            <img\n              className=\"imgSocial\"\n              src=\"https://cdn-icons-png.flaticon.com/512/174/174857.png\"\n            />\n            <p className=\"socialText\">LinkedIn</p>\n          </a>\n\n          <a\n            className=\"social3\"\n            href=\"https://twitter.com/TomRadi1\"\n            target=\"_blank\"\n          >\n            <img\n              className=\"imgSocial\"\n              src=\"https://www.pngkey.com/png/full/2-27646_twitter-logo-png-transparent-background-logo-twitter-png.png\"\n            />\n            <p className=\"socialText\">Twitter</p>\n          </a>\n\n          <a\n            className=\"social4\"\n            href=\"https://www.instagram.com/radic.o_o/\"\n            target=\"_blank\"\n          >\n            <img\n              className=\"imgSocial\"\n              src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a5/Instagram_icon.png/640px-Instagram_icon.png\"\n            />\n            <p className=\"socialText\">Instagram</p>\n          </a>\n        </div>\n      </div>\n\n      <div onClick={handleClick} id=\"nav-icon2\" className={Burger}>\n        <span></span>\n        <span></span>\n        <span></span>\n        <span></span>\n        <span></span>\n        <span></span>\n      </div>\n    </div>\n  );\n}\n\n/*<div className=\"pushMenu\">\n      <ul>\n        <li src=\"#\">Home</li>\n        <li src=\"#\">Portfolio</li>\n        <li src=\"#\">Contact</li>\n        <li src=\"#\">About me</li>\n      </ul>\n    </div>\n*/\n","C:\\Users\\Radicc\\Desktop\\Portfolio\\Portfolio\\src\\tooler.js",["174","175","176","177","178","179","180","181","182","183"],[],"import React, { Component } from \"react\";\nimport \"./App.css\";\n\nexport default function Tooler() {\n  return (\n    <div className=\"toolsBar\">\n      <img\n        className=\"toolsLogo\"\n        src=\"https://www.freepnglogos.com/uploads/html5-logo-png/html5-logo-html-logo-0.png\"\n      />\n\n      <img\n        className=\"toolsLogo\"\n        src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/6/62/CSS3_logo.svg/800px-CSS3_logo.svg.png\"\n      />\n\n      <img\n        className=\"toolsLogo\"\n        src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/9/96/Sass_Logo_Color.svg/1280px-Sass_Logo_Color.svg.png\"\n      />\n\n      <img\n        className=\"toolsLogo\"\n        src=\"https://www.freepnglogos.com/uploads/javascript-png/js-logo-png-5.png\"\n      />\n\n      <img\n        className=\"toolsLogo\"\n        src=\"https://cdn.worldvectorlogo.com/logos/typescript-2.svg\"\n      />\n\n      <img\n        className=\"toolsLogo\"\n        src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a7/React-icon.svg/2300px-React-icon.svg.png\"\n      />\n\n      <img\n        className=\"toolsLogo\"\n        src=\"https://raw.githubusercontent.com/webpack/media/master/logo/icon-square-big.png\"\n      />\n\n      <img\n        className=\"toolsLogo\"\n        src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a1/AJAX_logo_by_gengns.svg/2560px-AJAX_logo_by_gengns.svg.png\"\n      />\n\n      <img\n        className=\"toolsLogo\"\n        src=\"https://git-scm.com/images/logos/downloads/Git-Icon-1788C.png\"\n      />\n    </div>\n  );\n}\n","C:\\Users\\Radicc\\Desktop\\Portfolio\\Portfolio\\src\\Footer.js",["184","185","186","187","188","189","190","191","192","193","194","195"],[],"import React from \"react\";\nimport \"./App.css\";\nimport \"./Footer.css\";\nimport Mail from \"../src/images/mail.png\";\n\nexport default function Footer() {\n  return (\n    <div id=\"Contact\" className=\"containerFooter\">\n      <div className=\"MailForm-Footer2\">\n        <div className=\"WhitePaper\">\n          <div className=\"LeftPaper\">\n            <img\n              className=\"CvPicture\"\n              src=\"https://www.fredericvigier.com/wp-content/uploads/2021/01/directeur-communication-photo-cv.jpg\"\n            ></img>\n            <div className=\"Education\">\n              <h2>Education</h2>\n              <p>\n                High school eletronical enginering Karola Adlera / Bratislava /\n                Slovakia / 2016-2020\n              </p>\n            </div>\n            <div className=\"Reference\">\n              <h2>Reference</h2>\n              <p>2021 - 2022</p>\n              <p>Elektrikár</p>\n              <p>GAOL Energy Slovakia, s.r.o.</p>\n            </div>\n            <div className=\"CvContact\">\n              <h3>Phone</h3>\n              <p>+421 000 000 000</p>\n\n              <h3>Email</h3>\n              <p>tomas.radic00@gmail.com</p>\n\n              <h3>Website</h3>\n              <a>https://radicc.github.io/Portfolio/</a>\n\n              <h3>Address</h3>\n              <p>Malacky, Slovakia</p>\n            </div>\n          </div>\n          <div className=\"RightPaper\">\n            <div className=\"NameTitul\">\n              <h1>TOMÁŠ RADIČ</h1>\n              <p>SELFTHOUGHT FRONTEND DEVELOPER</p>\n            </div>\n            <div className=\"AboutMe\">\n              <h3>ABOUT ME</h3>\n              <p>\n                I am a selfthouhgt student of frontend developing trying to\n                change profession. Experienced in HTML,CSS and JavaScript\n                specializing in ReactJS library. Implementing CSS-extansion SASS\n                and JavaScript-syntactical superset TypeScript.\n              </p>\n            </div>\n            <div className=\"AboutMe\">\n              <h3>WORK EXPERIENCE</h3>\n              <p>\n                I am a selfthouhgt student of frontend developing trying to\n                change profession. Experienced in HTML,CSS and JavaScript\n                specializing in ReactJS library. Implementing CSS-extansion SASS\n                and JavaScript-syntactical superset TypeScript.\n              </p>\n            </div>\n            <div className=\"AboutMe\">\n              <h3>SOFTWARE SKILL</h3>\n              <p>\n                I am a selfthouhgt student of frontend developing trying to\n                change profession. Experienced in HTML,CSS and JavaScript\n                specializing in ReactJS library. Implementing CSS-extansion SASS\n                and JavaScript-syntactical superset TypeScript.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n      <div className=\"Footer1\">\n        <a\n          className=\"socialFooterContainer1\"\n          href=\"https://github.com/Radicc\"\n          target=\"_blank\"\n        >\n          <img\n            className=\"footerSocial\"\n            src=\"https://cdn-icons-png.flaticon.com/512/25/25231.png\"\n          />\n          <p className=\"footerText\">GitHub</p>\n        </a>\n        <a\n          className=\"socialFooterContainer2\"\n          href=\"https://www.linkedin.com/in/tom%C3%A1%C5%A1-radi%C4%8D-068044221/\"\n          target=\"_blank\"\n        >\n          <img\n            className=\"footerSocial\"\n            src=\"https://cdn-icons-png.flaticon.com/512/174/174857.png\"\n          />\n    